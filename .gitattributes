# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Force LF for these files even on Windows
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.md text eol=lf
Dockerfile text eol=lf
Dockerfile.dev text eol=lf
*.sh text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
