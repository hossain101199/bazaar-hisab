FROM node:20-alpine

WORKDIR /app

# copy package files before source — preserves layer cache when only source changes
COPY package.json package-lock.json ./
RUN npm install

EXPOSE 3000

# src/ is volume-mounted by docker-compose — not copied here
# --hostname 0.0.0.0 required — without it Next.js binds to 127.0.0.1 inside the container
# port mapping (3000:3000) would be unreachable from the host browser
CMD ["node_modules/.bin/next", "dev", "--hostname", "0.0.0.0"]
